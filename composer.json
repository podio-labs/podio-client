{
    "name": "podio-labs/podio-client",
    "description": "Modern, framework-agnostic PHP client for the Podio API. PSR-18, OAuth handled, fully typed.",
    "type": "library",
    "keywords": [
        "podio",
        "podio-api",
        "podio-client",
        "podio-sdk",
        "psr-18"
    ],
    "homepage": "https://github.com/podio-labs/podio-client",
    "license": "MIT",
    "authors": [
        {
            "name": "Karim Tao"
        }
    ],
    "support": {
        "issues": "https://github.com/podio-labs/podio-client/issues",
        "source": "https://github.com/podio-labs/podio-client"
    },
    "require": {
        "php": "^8.3",
        "php-http/discovery": "^1.14",
        "psr/http-client": "^1.0",
        "psr/http-client-implementation": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-factory-implementation": "^1.0",
        "psr/http-message": "^1.0 || ^2.0",
        "psr/simple-cache": "^3.0"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.8",
        "laravel/pao": "^1.1",
        "laravel/pint": "^1.29",
        "nyholm/psr7": "^1.8",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpstan/phpstan": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "Podio\\Client\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Podio\\Client\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
